# =========================================================================
# BumperBid backend env
# =========================================================================

NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
TRUST_PROXY=false

# Postgres
DATABASE_URL=postgres://bumperbid:bumperbid@localhost:5432/bumperbid

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT / cookies
JWT_ACCESS_SECRET=change_me_32_random_bytes_minimum
JWT_REFRESH_SECRET=change_me_different_32_random_bytes
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
COOKIE_SECRET=change_me_cookie_signing_secret
CSRF_SECRET=change_me_csrf_secret_32_random_bytes

# OTP (dev: console; prod: Twilio/MSG91)
OTP_PROVIDER=console
OTP_LEN=6
OTP_TTL_SEC=300
OTP_COOLDOWN_SEC=60
OTP_MAX_ATTEMPTS=3
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# S3 / R2
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=bumperbid-uploads
S3_REGION=auto
S3_PUBLIC_BASE=https://uploads.bumperbid.in

# AWS Rekognition
AWS_REGION=ap-south-1
AWS_REKOGNITION_KEY=
AWS_REKOGNITION_SECRET=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM="BumperBid <no-reply@bumperbid.in>"

# Push (FCM + Web Push)
FCM_SERVICE_ACCOUNT_JSON=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@bumperbid.in

# Payments (QR + UPI)
UPI_PAYEE_ID=bumperbid@hdfcbank
UPI_PAYEE_NAME=BumperBid Pvt Ltd
UPI_QR_IMAGE_URL=https://assets.bumperbid.in/pay/qr.png
PAYMENT_MIN_AMOUNT_PAISA=10000

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_LEVEL=info

# Feature flags
ENABLE_PROXY_BIDS=true
ENABLE_WATCHLIST=true
ENABLE_KYC_REQUIRED_FOR_SELLER=true
