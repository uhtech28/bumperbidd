{
  "name": "@bumperbid/backend",
  "version": "3.0.0",
  "description": "BumperBid - Real-time vehicle auction platform (NestJS + Postgres + Redis + Socket.IO)",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:worker": "node dist/queues/worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "postinstall": "prisma generate",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "test": "jest",
    "test:cov": "jest --coverage --coverageThreshold='{\"global\":{\"lines\":80,\"statements\":80}}'",
    "test:e2e": "jest --config test/jest-e2e.config.js",
    "test:load": "k6 run test/load/place-bid.k6.js"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.549.0",
    "@aws-sdk/client-s3": "^3.549.0",
    "@aws-sdk/s3-request-presigner": "^3.549.0",
    "@nest-lab/throttler-storage-redis": "^1.1.0",
    "@nestjs/bullmq": "^10.1.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/schedule": "^4.0.1",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/websockets": "^10.3.0",
    "@prisma/client": "^5.10.2",
    "@sentry/node": "^7.109.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "csrf-csrf": "^3.0.3",
    "firebase-admin": "^12.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "libphonenumber-js": "^1.10.54",
    "nestjs-pino": "^4.0.0",
    "pino": "^8.17.2",
    "pino-http": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "prom-client": "^15.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "reflect-metadata": "^0.2.1",
    "resend": "^3.2.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5",
    "twilio": "^4.21.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "@types/web-push": "^3.6.3",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prisma": "^5.10.2",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "overrides": {
    "supports-color": "8.1.1"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
